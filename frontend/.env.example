# Environment (dev, staging, prod)
VITE_ENV=dev

# Use mock API for development (true) or connect to real backend (false)
VITE_USE_MOCK=true

# API Gateway REST endpoint
VITE_API_ENDPOINT=https://api-dev.aws-governance-demos.example.com

# WebSocket endpoint for real-time updates
VITE_WS_ENDPOINT=wss://ws-dev.aws-governance-demos.example.com

# API Gateway API Key
VITE_API_KEY=your-api-key-here

# AWS Region
VITE_AWS_REGION=us-east-1

# Cognito Identity Pool ID (for unauthenticated access to CloudWatch Logs)
VITE_IDENTITY_POOL_ID=us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Neptune endpoint (optional, can be fetched from API)
VITE_NEPTUNE_ENDPOINT=your-neptune-cluster.cluster-xxxxxxxxxx.us-east-1.neptune.amazonaws.com

# Step Functions State Machine ARN (optional, can be fetched from API)
VITE_APPROVAL_STATE_MACHINE_ARN=arn:aws:states:us-east-1:123456789012:stateMachine:ApprovalWorkflow-dev
